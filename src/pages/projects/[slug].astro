---
import BaseLayout from '../../layouts/BaseLayout.astro';
import projects from '../../data/projects.json';

export function getStaticPaths() {
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

const percent = Math.min(Math.round((project.raised / project.goal) * 100), 100);
const remaining = project.goal - project.raised;

const statusLabel = {
  'seeking-funding': 'Seeking Funding',
  'partially-funded': 'Partially Funded',
  'funded': 'Fully Funded',
};

const statusColor = {
  'seeking-funding': 'text-gold bg-gold/10 border-gold/20',
  'partially-funded': 'text-primary bg-primary/10 border-primary/20',
  'funded': 'text-green-700 bg-green-50 border-green-200',
};

const subject = encodeURIComponent(`Funding inquiry: ${project.title}`);
const body = encodeURIComponent(`Hi Dallas,\n\nI'm interested in funding the project: ${project.title} (${project.location}).\n\nPlease let me know how to proceed.\n\nThank you.`);
const mailtoLink = `mailto:dallas@restorethelast.org?subject=${subject}&body=${body}`;
---

<BaseLayout title={project.title} description={project.summary}>

  <!-- Hero -->
  <section class="bg-white border-b border-primary/10">
    <div class="container-narrow py-12 px-6 md:px-12">
      <a href="/projects" class="text-primary text-sm font-bold font-sans hover:text-medium transition-colors mb-6 inline-block">← All Projects</a>
      <div class="grid md:grid-cols-[1fr_340px] gap-12 items-start">

        <!-- Left -->
        <div>
          <span class={`inline-block text-xs font-bold font-sans uppercase tracking-wide px-3 py-1 rounded-full border mb-4 ${statusColor[project.status]}`}>
            {statusLabel[project.status]}
          </span>
          <p class="label text-gold mb-2">{project.location}</p>
          <h1 class="text-dark text-3xl md:text-4xl font-serif font-bold leading-tight mb-4">
            {project.title}
          </h1>
          <p class="text-body/70 text-sm font-semibold uppercase tracking-wide mb-6">{project.population}</p>
          <img
            src={project.coverImage}
            alt={project.title}
            class="w-full rounded-2xl shadow-md mb-8"
            style="max-height: 420px; object-fit: cover;"
          />
          <div class="space-y-10">
            <div>
              <p class="label text-primary mb-3">About This Project</p>
              <p class="text-body text-lg leading-relaxed">{project.summary}</p>
            </div>
            <div>
              <p class="label text-primary mb-3">Why This Population</p>
              <p class="text-body text-lg leading-relaxed">{project.whyThisPopulation}</p>
            </div>
            <div>
              <p class="label text-primary mb-3">What Your Funding Covers</p>
              <div class="bg-light rounded-2xl p-6 border border-primary/10">
                <p class="text-body leading-relaxed">{project.whatWeFund}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Funding sidebar -->
        <div class="sticky top-24">
          <div class="bg-white rounded-2xl border border-primary/20 shadow-sm p-7">
            <p class="label text-primary mb-4">Funding Goal</p>
            <p class="font-serif text-4xl font-bold text-dark mb-1">${project.goal.toLocaleString()}</p>
            <p class="text-body/50 text-sm mb-6">total project cost</p>

            <!-- Progress bar -->
            <div class="mb-2">
              <div class="flex justify-between items-baseline mb-2">
                <span class="text-primary font-bold text-sm">${project.raised.toLocaleString()} raised</span>
                <span class="text-body/50 text-xs">{percent}%</span>
              </div>
              <div class="w-full bg-light rounded-full h-3 mb-2">
                <div
                  class="bg-primary rounded-full h-3 transition-all duration-500"
                  style={`width: ${percent}%`}
                ></div>
              </div>
              {project.status !== 'funded' && (
                <p class="text-body/50 text-xs">${remaining.toLocaleString()} still needed</p>
              )}
            </div>

            <div class="border-t border-primary/10 my-6"></div>

            <a
              href={mailtoLink}
              class="btn-gold w-full text-center block text-base mb-3"
            >
              Fund this project
            </a>
            <p class="text-body/40 text-xs text-center">
              You'll be connected directly with our team to complete your gift.
            </p>

            <div class="border-t border-primary/10 my-6"></div>

            <div class="space-y-3 text-sm text-body/70">
              <div class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-light flex items-center justify-center flex-shrink-0 mt-0.5">
                  <div class="w-2 h-2 rounded-full bg-primary"></div>
                </div>
                <p>100% of your gift goes to this specific project</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-light flex items-center justify-center flex-shrink-0 mt-0.5">
                  <div class="w-2 h-2 rounded-full bg-primary"></div>
                </div>
                <p>You'll receive progress updates as the deployment moves forward</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-light flex items-center justify-center flex-shrink-0 mt-0.5">
                  <div class="w-2 h-2 rounded-full bg-primary"></div>
                </div>
                <p>Outcome report delivered when sessions are complete</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-deep text-white section-padding text-center">
    <div class="container-narrow">
      <h2 class="text-white text-3xl mb-6">Ready to fund this deployment?</h2>
      <a href={mailtoLink} class="btn-gold text-lg">Fund this project</a>
    </div>
  </section>

</BaseLayout>
