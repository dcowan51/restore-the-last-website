---
import BaseLayout from '../../layouts/BaseLayout.astro';
import projects from '../../data/projects.json';

export function getStaticPaths() {
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const isMajor = project.type === 'major';
const isClosed = project.type === 'specific' && project.status === 'closed';

const subject = encodeURIComponent(`Funding inquiry: ${project.title}`);
const body = encodeURIComponent(`Hi Dallas,\n\nI'm interested in funding the project: ${project.title} (${project.location}).\n\nPlease let me know how to proceed.\n\nThank you.`);
const mailtoLink = `mailto:dallas@restorethelast.org?subject=${subject}&body=${body}`;

const badgeLabel = isMajor
  ? 'Major Initiative'
  : (project.status === 'open' ? 'Open' : 'Fully Funded');

const badgeColor = isMajor
  ? 'text-primary bg-primary/10 border-primary/20'
  : (project.status === 'open' ? 'text-gold bg-gold/10 border-gold/20' : 'text-green-700 bg-green-50 border-green-200');

const ctaLabel = isMajor
  ? 'Contact us to fund this'
  : (isClosed ? 'Project fully funded' : 'Fund this project');
---

<BaseLayout title={project.title} description={project.summary}>

  <!-- Hero -->
  <section class="bg-white border-b border-primary/10">
    <div class="container-narrow py-10 md:py-12 px-6 md:px-12">
      <a href="/projects" class="text-primary text-sm font-bold font-sans hover:text-medium transition-colors mb-6 inline-block">← All Current Projects</a>

      <!-- Mobile sidebar -->
      <div class="block md:hidden mb-8">
        <div class="bg-white rounded-2xl border border-primary/20 shadow-sm p-6">
          {isMajor ? (
            <>
              <p class="label text-primary mb-3">Ongoing Initiative</p>
              <p class="text-body text-sm leading-relaxed mb-5">
                This is a long-running deployment with continuing need. There's no single dollar goal — every gift goes toward keeping the work running and growing.
              </p>
            </>
          ) : (
            <>
              <p class="label text-primary mb-3">Project Cost</p>
              <p class="font-serif text-3xl font-bold text-dark mb-1">${project.goal.toLocaleString()}</p>
              <p class="text-body/50 text-sm mb-5">fully-costed deployment</p>
              {isClosed && (
                <p class="text-green-700 text-sm font-bold mb-4">✓ Fully funded — thank you.</p>
              )}
            </>
          )}
          {!isClosed && (
            <a href={mailtoLink} class="btn-gold w-full text-center block text-base mt-2">{ctaLabel}</a>
          )}
        </div>
      </div>

      <div class="grid md:grid-cols-[1fr_320px] gap-10 md:gap-12 items-start">

        <!-- Left: Content -->
        <div>
          <span class={`inline-block text-xs font-bold font-sans uppercase tracking-wide px-3 py-1 rounded-full border mb-4 ${badgeColor}`}>
            {badgeLabel}
          </span>
          <p class="label text-gold mb-2">{project.location}</p>
          <h1 class="text-dark text-2xl md:text-4xl font-serif font-bold leading-tight mb-4">
            {project.title}
          </h1>
          <p class="text-body/70 text-sm font-semibold uppercase tracking-wide mb-6">{project.population}</p>
          <img
            src={project.coverImage}
            alt={project.title}
            class="w-full rounded-2xl shadow-md mb-8 object-cover"
            style="max-height: 380px;"
          />
          <div class="space-y-8 md:space-y-10">
            <div>
              <p class="label text-primary mb-3">About This Project</p>
              <p class="text-body text-base md:text-lg leading-relaxed">{project.summary}</p>
            </div>
            <div>
              <p class="label text-primary mb-3">Why This Population</p>
              <p class="text-body text-base md:text-lg leading-relaxed">{project.whyThisPopulation}</p>
            </div>
            <div>
              <p class="label text-primary mb-3">What Your Funding Covers</p>
              <div class="bg-light rounded-2xl p-5 md:p-6 border border-primary/10">
                <p class="text-body leading-relaxed">{project.whatWeFund}</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Sidebar (desktop) -->
        <div class="hidden md:block md:sticky md:top-24">
          <div class="bg-white rounded-2xl border border-primary/20 shadow-sm p-7">
            {isMajor ? (
              <>
                <p class="label text-primary mb-4">Ongoing Initiative</p>
                <p class="text-body text-sm leading-relaxed mb-6">
                  This is a long-running deployment with continuing need. There's no single dollar goal — every gift helps keep the work running and growing.
                </p>
              </>
            ) : (
              <>
                <p class="label text-primary mb-4">Project Cost</p>
                <p class="font-serif text-4xl font-bold text-dark mb-1">${project.goal.toLocaleString()}</p>
                <p class="text-body/50 text-sm mb-6">fully-costed deployment</p>
                {isClosed && (
                  <p class="text-green-700 text-sm font-bold mb-4">✓ Fully funded — thank you.</p>
                )}
              </>
            )}

            <div class="border-t border-primary/10 my-6"></div>

            {!isClosed ? (
              <>
                <a href={mailtoLink} class="btn-gold w-full text-center block text-base mb-3">
                  {ctaLabel}
                </a>
                <p class="text-body/40 text-xs text-center">
                  You'll be connected directly with our team to complete your gift.
                </p>
              </>
            ) : (
              <a href="/projects" class="btn-primary w-full text-center block text-base">
                See other open projects
              </a>
            )}

            {project.orgUrl && (
              <div class="border-t border-primary/10 my-6">
                <a
                  href={project.orgUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary text-sm font-bold font-sans hover:text-medium transition-colors mt-6 inline-block"
                >
                  Visit organization's website →
                </a>
              </div>
            )}

            <div class="border-t border-primary/10 my-6"></div>

            <div class="space-y-3 text-sm text-body/70">
              <div class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-light flex items-center justify-center flex-shrink-0 mt-0.5">
                  <div class="w-2 h-2 rounded-full bg-primary"></div>
                </div>
                <p>100% of your gift goes to this specific project</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-light flex items-center justify-center flex-shrink-0 mt-0.5">
                  <div class="w-2 h-2 rounded-full bg-primary"></div>
                </div>
                <p>You'll receive progress updates as the deployment moves forward</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-light flex items-center justify-center flex-shrink-0 mt-0.5">
                  <div class="w-2 h-2 rounded-full bg-primary"></div>
                </div>
                <p>Outcome report delivered when sessions are complete</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  {!isClosed && (
    <section class="bg-deep text-white section-padding text-center">
      <div class="container-narrow">
        <h2 class="text-white text-2xl md:text-3xl mb-6">
          {isMajor ? 'Ready to partner on this initiative?' : 'Ready to fund this deployment?'}
        </h2>
        <a href={mailtoLink} class="btn-gold text-lg">{ctaLabel}</a>
      </div>
    </section>
  )}

</BaseLayout>
