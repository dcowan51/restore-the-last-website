---
import BaseLayout from '../../layouts/BaseLayout.astro';
import projects from '../../data/projects.json';

const statusLabel = {
  'seeking-funding': 'Seeking Funding',
  'partially-funded': 'Partially Funded',
  'funded': 'Fully Funded',
};

const statusColor = {
  'seeking-funding': 'text-gold bg-gold/10',
  'partially-funded': 'text-primary bg-primary/10',
  'funded': 'text-green-700 bg-green-50',
};
---

<BaseLayout title="Fund a Project" description="Choose a specific deployment to fund. Every dollar goes directly to a named project with a named population.">

  <!-- Hero -->
  <section class="bg-white section-padding border-b border-primary/10">
    <div class="container-narrow">
      <p class="label text-primary mb-4">Fund a Project</p>
      <div class="gold-line mb-8"></div>
      <h1 class="text-dark text-4xl md:text-5xl font-serif font-bold leading-tight max-w-3xl">
        Pick a project. Fund it. See what happens.
      </h1>
      <p class="text-body text-lg max-w-2xl mt-6 leading-relaxed">
        Every project below is a real deployment waiting for funding — a specific facility, a specific population, a specific dollar goal. Your giving goes directly to one of these.
      </p>
    </div>
  </section>

  <!-- Project Cards -->
  <section class="bg-offwhite section-padding">
    <div class="container-narrow">
      <div class="grid md:grid-cols-2 gap-5 md:gap-8">
        {projects.map(project => {
          const percent = Math.min(Math.round((project.raised / project.goal) * 100), 100);
          const remaining = project.goal - project.raised;
          return (
            <a
              href={`/projects/${project.slug}`}
              class="bg-white rounded-2xl overflow-hidden border border-primary/10 hover:border-primary/30 hover:shadow-lg transition-all duration-200 flex flex-col group"
            >
              <!-- Photo -->
              <div class="relative overflow-hidden">
                <img
                  src={project.coverImage}
                  alt={project.title}
                  class="w-full h-52 object-cover group-hover:scale-105 transition-transform duration-300"
                />
                <div class="absolute top-4 left-4">
                  <span class={`text-xs font-bold font-sans uppercase tracking-wide px-3 py-1 rounded-full ${statusColor[project.status]}`}>
                    {statusLabel[project.status]}
                  </span>
                </div>
              </div>

              <!-- Content -->
              <div class="p-7 flex flex-col flex-grow">
                <p class="label text-gold mb-2">{project.location}</p>
                <h3 class="text-xl font-serif font-bold text-dark mb-2">{project.title}</h3>
                <p class="text-body/70 text-xs font-semibold uppercase tracking-wide mb-4">{project.population}</p>
                <p class="text-body text-sm leading-relaxed mb-6 flex-grow line-clamp-3">{project.summary}</p>

                <!-- Progress -->
                <div class="mt-auto">
                  <div class="flex justify-between items-baseline mb-2">
                    <span class="text-primary font-bold font-sans text-sm">${project.raised.toLocaleString()} raised</span>
                    <span class="text-body/50 text-xs">Goal: ${project.goal.toLocaleString()}</span>
                  </div>
                  <div class="w-full bg-light rounded-full h-2 mb-2">
                    <div
                      class="bg-primary rounded-full h-2 transition-all duration-500"
                      style={`width: ${percent}%`}
                    ></div>
                  </div>
                  <div class="flex justify-between items-baseline">
                    <span class="text-body/50 text-xs">{percent}% funded</span>
                    {project.status !== 'funded' && (
                      <span class="text-body/50 text-xs">${remaining.toLocaleString()} remaining</span>
                    )}
                  </div>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Partner CTA -->
  <section class="bg-white section-padding border-t border-primary/10">
    <div class="container-narrow max-w-3xl text-center mx-auto">
      <p class="label text-primary mb-4">Are You an Organization?</p>
      <h2 class="mb-6">Apply to become a funded partner.</h2>
      <p class="text-body text-lg leading-relaxed mb-8">
        If you run an established facility serving trauma-affected populations, we want to hear from you. We fund the technology, the training, and the support — you bring the people and the commitment.
      </p>
      <a href="/partners#apply" class="btn-primary text-lg">Apply for funding</a>
    </div>
  </section>

</BaseLayout>
