---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Home" description="Restore the Last funds direct neurofeedback technology into partner facilities serving trafficking survivors, foster youth, and trauma-affected communities.">

  <!-- Hero -->
  <section class="bg-white min-h-[88vh] flex items-center">
    <div class="max-w-7xl mx-auto px-6 md:px-12 w-full">
      <div class="grid md:grid-cols-2 gap-12 items-center py-16">

        <!-- Left: Text -->
        <div>
          <div class="gold-line mb-8"></div>
          <h1 class="text-dark text-4xl md:text-5xl font-serif font-bold leading-tight mb-6">
            Healing reaches the people it was
            <span class="bg-primary text-white px-3 py-1 rounded-xl inline">never supposed to miss.</span>
          </h1>
          <p class="text-body text-lg max-w-md mb-10 leading-relaxed">
            Restore the Last funds direct neurofeedback technology into partner facilities serving trafficking survivors, foster youth, and trauma-affected communities.
          </p>
          <div class="flex flex-wrap items-center gap-4 mb-12">
            <a href="/how-it-works" class="btn-primary text-base">See the work</a>
            <a href="/give" class="text-primary font-bold font-sans hover:text-medium transition-colors">Give now →</a>
          </div>

          <!-- Proof card -->
          <div class="flex items-center gap-4 bg-light rounded-xl p-4 max-w-sm">
            <img src="/IMG_3776.jpeg" alt="ONUVA session" class="w-14 h-14 rounded-lg object-cover flex-shrink-0" />
            <div>
              <p class="text-primary font-bold font-sans text-sm">18,000+ sessions delivered</p>
              <p class="text-body text-xs mt-1">Across partner facilities in El Salvador and Arizona</p>
            </div>
          </div>
        </div>

        <!-- Right: Photo -->
        <div class="hidden md:block">
          <img
            src="/IMG_3305.jpg"
            alt="Young girl smiling during a neurofeedback session at ONUVA"
            class="w-full rounded-2xl shadow-xl"
            style="height: 580px; object-fit: cover; object-position: center top;"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- Proof Bar -->
  <section class="bg-primary text-white py-12 px-6">
    <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-8 text-center">
      <div>
        <p class="font-serif text-4xl font-bold mb-2">97%</p>
        <p class="text-white/80 text-sm">showed improvement</p>
      </div>
      <div>
        <p class="font-serif text-4xl font-bold mb-2">50%</p>
        <p class="text-white/80 text-sm">symptom reduction after one session</p>
      </div>
      <div>
        <p class="font-serif text-4xl font-bold mb-2">18,000+</p>
        <p class="text-white/80 text-sm">sessions delivered</p>
      </div>
    </div>
  </section>

  <!-- Who We Serve -->
  <section class="bg-light section-padding">
    <div class="container-narrow">
      <p class="label text-primary mb-4">Who We Serve</p>
      <h2 class="mb-12">The people the system forgot.</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-lg p-8 shadow-sm">
          <h3 class="text-xl mb-4">Sex Trafficking Survivors</h3>
          <p class="text-body">
            Survivors carry trauma in their nervous systems long after rescue. We fund the technology that helps their bodies feel safe again.
          </p>
        </div>
        <div class="bg-white rounded-lg p-8 shadow-sm">
          <h3 class="text-xl mb-4">Foster Youth</h3>
          <p class="text-body">
            Aged-out foster youth face the world with dysregulated nervous systems. We equip the organizations that house and serve them.
          </p>
        </div>
        <div class="bg-white rounded-lg p-8 shadow-sm">
          <h3 class="text-xl mb-4">Developing Nations</h3>
          <p class="text-body">
            In countries rebuilding from violence and poverty, trauma is everywhere. We place technology where traditional therapy cannot reach.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- The Model -->
  <section class="bg-deep text-white section-padding">
    <div class="container-narrow">
      <p class="label text-gold mb-4">The Model</p>
      <h2 class="text-white mb-12">Four steps. One mission.</h2>
      <div class="grid md:grid-cols-4 gap-8">
        <div class="text-center">
          <p class="label text-gold text-lg mb-3">01</p>
          <p class="font-serif text-xl font-bold mb-3">Fund</p>
          <p class="text-white/70 text-sm">Donors fund specific projects with full transparency into where every dollar goes.</p>
        </div>
        <div class="text-center">
          <p class="label text-gold text-lg mb-3">02</p>
          <p class="font-serif text-xl font-bold mb-3">Deploy</p>
          <p class="text-white/70 text-sm">We place neurofeedback technology directly into partner facilities on the ground.</p>
        </div>
        <div class="text-center">
          <p class="label text-gold text-lg mb-3">03</p>
          <p class="font-serif text-xl font-bold mb-3">Train</p>
          <p class="text-white/70 text-sm">On-site staff receive full training to deliver sessions independently.</p>
        </div>
        <div class="text-center">
          <p class="label text-gold text-lg mb-3">04</p>
          <p class="font-serif text-xl font-bold mb-3">Measure</p>
          <p class="text-white/70 text-sm">We track outcomes session by session. Real numbers. Real recovery.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Pull Quote -->
  <section class="bg-offwhite section-padding">
    <div class="container-narrow flex items-start gap-6 max-w-3xl mx-auto">
      <div class="gold-line-left flex-shrink-0 hidden md:block"></div>
      <blockquote class="font-serif italic text-2xl md:text-3xl text-dark leading-snug">
        The technology exists. The need exists. The distance between them is what we close.
      </blockquote>
    </div>
  </section>

  <!-- Proof Partners -->
  <section class="bg-white section-padding">
    <div class="container-narrow">
      <p class="label text-primary mb-4">Where It's Working</p>
      <h2 class="mb-12">Proof, not promises.</h2>
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <p class="label text-gold mb-2">ONUVA Children's Home</p>
          <p class="text-sm text-body/60 mb-4">El Salvador</p>
          <p class="font-serif text-3xl font-bold text-primary mb-4">97% showed improvement</p>
          <p class="text-body">
            28 participants across two years. 50% symptom reduction after a single session. 70% by session seven. 18,000+ sessions delivered. Teachers, children, and staff — all carrying trauma, all showing measurable recovery.
          </p>
        </div>
        <div>
          <p class="label text-gold mb-2">Thrive</p>
          <p class="text-sm text-body/60 mb-4">Arizona, USA</p>
          <p class="font-serif text-3xl font-bold text-primary mb-4">25–30 sessions/week</p>
          <p class="text-body">
            Aged-out foster youth, ages 18–25. Residents are sleeping through the night. Ten earned their driver's licenses. Five graduated high school. The nervous system calmed down — and everything else followed.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Partner Videos -->
  <section class="bg-light section-padding">
    <div class="max-w-5xl mx-auto px-6 md:px-12">
      <div class="text-center mb-12">
        <p class="label text-primary mb-4">From Our Partners</p>
        <h2 class="mb-4">Hear it directly from the field.</h2>
        <p class="text-body max-w-xl mx-auto">
          These are the people doing the work. See what nervous system restoration looks like when it reaches the people it was meant for.
        </p>
      </div>

      <!-- Videos: landscape + portrait balanced -->
      <div class="flex flex-col md:flex-row gap-8 justify-center items-start">

        <!-- Landscape video -->
        <div class="w-full md:w-[500px] flex-shrink-0">
          <p class="label text-gold mb-3">Thrive — Arizona</p>
          <div class="aspect-video rounded-lg overflow-hidden shadow-md">
            <iframe
              src="https://www.youtube.com/embed/utLjfuTNIU8"
              title="Thrive Arizona — Restore the Last"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="w-full h-full"
              loading="lazy"
            ></iframe>
          </div>
        </div>

        <!-- Portrait reel -->
        <div class="w-[165px] mx-auto md:mx-0 flex-shrink-0">
          <p class="label text-gold mb-3">ONUVA — El Salvador</p>
          <div class="rounded-lg overflow-hidden shadow-md" style="aspect-ratio: 9/16;">
            <iframe
              src="https://www.youtube.com/embed/uTvgBmxbzeQ"
              title="ONUVA El Salvador — Restore the Last"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              class="w-full h-full"
              loading="lazy"
            ></iframe>
          </div>
        </div>

      </div>

      <div class="mt-12 text-center">
        <a href="/partners" class="btn-primary">See all our partners</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-deep text-white section-padding">
    <div class="container-narrow text-center">
      <h2 class="text-white text-3xl md:text-4xl mb-6">Every dollar has a destination.</h2>
      <p class="text-white/80 max-w-xl mx-auto mb-10">
        Your giving funds a specific project. You see where it goes, who it reaches, and what changes. No black boxes. No overhead mystery.
      </p>
      <a href="/give" class="btn-gold text-lg">Partner with us</a>
    </div>
  </section>

</BaseLayout>
