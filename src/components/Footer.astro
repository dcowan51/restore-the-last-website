---
const year = new Date().getFullYear();
---

<footer class="bg-deep text-white">
  <div class="max-w-6xl mx-auto px-6 md:px-12 py-12 md:py-16">
    <div class="grid md:grid-cols-3 gap-8 md:gap-12">
      <!-- Brand -->
      <div>
        <p class="font-serif text-2xl font-bold text-gold mb-4">Restore the Last</p>
        <p class="text-white/70 text-sm leading-relaxed">
          Funding nervous system restoration for survivors of trafficking, foster care, and violence.
        </p>
      </div>

      <!-- Links -->
      <div>
        <p class="label text-gold mb-4">Navigate</p>
        <div class="flex flex-col gap-2">
          <a href="/about" class="text-white/70 hover:text-white text-sm transition-colors">About</a>
          <a href="/how-it-works" class="text-white/70 hover:text-white text-sm transition-colors">How It Works</a>
          <a href="/impact" class="text-white/70 hover:text-white text-sm transition-colors">Impact</a>
          <a href="/partners" class="text-white/70 hover:text-white text-sm transition-colors">Partners</a>
          <a href="/give" class="text-white/70 hover:text-white text-sm transition-colors">Give</a>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <p class="label text-gold mb-4">Contact</p>
        <a href="mailto:dallas@restorethelast.org" class="text-white/70 hover:text-white text-sm transition-colors">
          dallas@restorethelast.org
        </a>
      </div>
    </div>

    <!-- Scripture + Copyright -->
    <div class="mt-16 pt-8 border-t border-white/10 text-center">
      <p class="font-serif italic text-gold text-lg mb-4">
        "He restores my soul." — Psalm 23:3
      </p>
      <p class="text-white/40 text-xs">
        &copy; {year} Restore the Last. All rights reserved.
      </p>
    </div>
  </div>
</footer>
